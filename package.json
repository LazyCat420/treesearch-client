{
  "name": "cannabis-researcher",
  "version": "0.1.0",
  "description": "Unified cannabis data warehouse + analysis service",
  "scripts": {
    "dev": "uvicorn main:app --host 0.0.0.0 --port 8005 --reload",
    "start": "uvicorn main:app --host 0.0.0.0 --port 8005",
    "deploy": "./deploy.sh"
  },
  "deploy": {
    "image": "cannabis-researcher",
    "port": 8005,
    "env": {
      "PORT": "8005",
      "KANNAPEDIA_DATA_DIR": ""
    }
  }
}
